{
  "name": "C64 Standard",
  "description": "Standard Commodore 64 project with common equates and basic stub.",
  "variables": {
    "START_ADDR": "$0801"
  },
  "structure": [
    "src",
    "assets"
  ],
  "files": [
    {
      "target": "src/main.asm",
      "content": "; Project: {{PROJECT_NAME}}
.target c64
.org {{START_ADDR}}

; BASIC stub: 10 SYS 2061 ($080D)
.byte $0B, $08, $0A, $00, $9E, $32, $30, $36, $31, $00, $00, $00

start:
    lda #$00
    sta $d020 ; Border black
    sta $d021 ; BG black

    ldx #$00
.loop:
    lda message,x
    beq .done
    jsr $ffd2 ; CHROUT
    inx
    jmp .loop

.done:
    rts

message: .text "HELLO FROM {{PROJECT_NAME}}", 0
"
    },
    {
      "target": "README.md",
      "content": "# {{PROJECT_NAME}}
Commodore 64 assembly project.
Uses standard Kernal ROM addresses for output.
"
    }
  ]
}
